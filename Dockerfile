FROM golang:1.25-bookworm

# Указываем рабочую директорию внутри контейнера
# Все следующие команды будут выполняться относительно /app
WORKDIR /app

# Копируем ВСЕ файлы из текущей папки (с локального компа)
# внутрь контейнера в папку /app
COPY . .

# Скачиваем и приводим в порядок зависимости Go
# (добавит недостающие, удалит лишние из go.mod/go.sum)
RUN go mod tidy
## Скомпилировать файл на этапе сборки
RUN go build -o /app/exe main.go

# Запуск скомпилированного бинарника
CMD ["/app/exe"]